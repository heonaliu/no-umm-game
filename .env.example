# Firebase Realtime Database — required for cross-device multiplayer
# 1. Go to https://console.firebase.google.com/ → Create a project
# 2. Add a Web app → copy the config values below
# 3. In Firebase console → Build → Realtime Database → Create database (test mode)
# 4. Copy this file to .env.local and fill in the values

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
